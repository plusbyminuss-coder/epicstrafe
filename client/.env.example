# Public API used by the Vite development proxy.
# Keep the default to use the original public data without a local backend.
VITE_API_PROXY_TARGET=https://strafes.fiveman1.net

# Optional: use this for frontend-only deployments. Login will continue on the
# specified site because OAuth sessions cannot cross domains.
# VITE_EXTERNAL_AUTH_ORIGIN=https://strafes.fiveman1.net
