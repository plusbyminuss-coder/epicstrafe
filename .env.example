# Strafes API
STRAFES_KEY=replace_with_your_strafes_api_key

# Authentication database (strafes_auth_users)
AUTH_DB_USER=replace_with_your_mysql_user
AUTH_DB_PASSWORD=replace_with_your_mysql_password

# Roblox OAuth application
ROBLOX_CLIENT_ID=replace_with_your_roblox_client_id
ROBLOX_CLIENT_SECRET=replace_with_your_roblox_client_secret

# Exact public backend origin; no trailing slash
BASE_URL=http://localhost:8080

# Generate a long random value, for example: openssl rand -hex 32
COOKIE_SECRET=replace_with_a_long_random_secret

# strafes_globals database
STRAFES_DB_USER=replace_with_your_mysql_user
STRAFES_DB_PASSWORD=replace_with_your_mysql_password

# Server configuration
PORT=8080
# TRUST_PROXY=1
# GOOGLE_SITE_VERIFICATION=
